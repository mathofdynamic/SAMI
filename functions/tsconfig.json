{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": false,
    "noEmit": true
  },
  "include": ["./**/*.ts", "../src/types.ts", "../src/utils.ts", "../src/presets.ts", "../src/pageSpec.ts", "../src/colorSync.ts"]
}
